# pimphand/gdrive — required .env variables for the published example (/gdrive)
#
# Copy these lines into your Laravel .env file:

GDRIVE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GDRIVE_CLIENT_SECRET=your-client-secret
GDRIVE_REDIRECT_URI=http://localhost:8000/auth/google/callback

# Optional — defaults shown
# GDRIVE_APP_FOLDER=pimpdrive
# GDRIVE_TOKEN_ENCRYPTION_KEY=   # falls back to APP_KEY

# Google Cloud Console setup:
# 1. Enable Google Drive API
# 2. Create OAuth 2.0 Web Client
# 3. Add authorized redirect URI: http://localhost:8000/auth/google/callback
# 4. After publish, run: php artisan serve
# 5. Open http://localhost:8000/gdrive and click "Connect Google Drive"
